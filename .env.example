DB_PASSWORD=change-me-strong-password
JWT_SECRET=change-me-to-a-random-64-char-string
ALLOWED_ORIGIN=https://your-domain.com

# --- Reverse Proxy (optional) ---
# Set to your domain for automatic TLS (e.g. SITE_ADDRESS=your-domain.com).
# Leave as :80 behind a reverse proxy (disables Caddy's auto-HTTPS).
# SITE_ADDRESS=:80
# Trusted proxy IPs/CIDRs for correct client IP detection (rate limiting, audit).
# Leave empty to trust all proxies (default).
# TRUSTED_PROXIES=172.18.0.0/16
# Host port mappings (change if your reverse proxy expects different ports).
# HTTP_PORT=80
# HTTPS_PORT=443
